# Frontend build-time configuration (Vite inlines env vars at build time).
# Copy to .env.local for local development (.env.local is gitignored).
#
# In production, set VITE_API_URL in your hosting/CI environment before `pnpm build`.
# Use the Django API ORIGIN with NO trailing slash and NO /api suffix.
#   Dev:  http://localhost:8000
#   Prod: https://api.yourdomain.com
VITE_API_URL=http://localhost:8000
